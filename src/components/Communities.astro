---
import { Image } from "astro:assets";

interface Community {
  logo: string;
  name: string;
  desc: string;
}

interface Props {
  communities: readonly Community[];
  title?: string;
}

const { communities, title = "Comunidades" } = Astro.props;
---

<div class="space-y-4">
  <h3 class="text-tx-2 text-balance">{title}</h3>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pb-4">
    {
      communities.map((c) => (
        <div class="border border-ui p-4 h-[200px] flex flex-col justify-center items-center text-center gap-4">
          <div class="h-[200px] w-full flex items-center justify-center shrink-0">
            <Image
              src={c.logo}
              alt={c.name}
              width={200}
              height={200}
              class="h-[200px] w-auto max-w-full object-contain"
            />
          </div>
        </div>
      ))
    }
  </div>
</div>
