---
import { es } from "../i18n/es";
import { en } from "../i18n/en";
import { lanAsciiArt, lanAsciiScale, onlineAscii } from "../data/lanAscii";

interface Props {
  lang?: "en" | "es";
}

const { lang = "es" } = Astro.props;
const content = lang === "en" ? en.bento : es.bento;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <div
    class="p-4 border border-ui-2 flex flex-col gap-1 items-center text-center"
  >
    <span class="text-4xl font-sans">54</span>
    <span class="text-tx-2">{content.hours}</span>
  </div>
  <div
    class="p-4 border border-ui-2 flex flex-col gap-1 items-center text-center"
  >
    <span class="text-4xl font-sans">4</span>
    <span class="text-tx-2">{content.tracks}</span>
  </div>
  <div
    class="p-4 border border-ui-2 flex flex-col gap-1 items-center text-center"
  >
    <span class="text-4xl font-sans">150</span>
    <span class="text-tx-2">{content.participants}</span>
  </div>
  <div
    class="col-span-1 md:col-span-3 border border-ui-2 p-2 grid grid-cols-1 md:grid-cols-3 gap-2"
  >
    <div class="relative w-40 h-40 shrink-0 overflow-hidden flex items-center justify-center justify-self-center">
      <div
        class="absolute left-1/2 top-1/2"
        style="transform: translate(-50%, -50%) scale(0.5); transform-origin: center center;"
      >
        <pre class="font-mono text-[4px] md:text-[5px] leading-none text-tx select-none">
          {onlineAscii}
        </pre>
      </div>
    </div>
    <div
      class="col-span-1 md:col-span-2 flex flex-col items-stretch md:items-start justify-center text-center md:text-left"
    >
      <p class="text-4xl font-sans text-center">{content.online.title}</p>
      <br />
      <p class="text-tx-2">
        {content.online.desc.split("[")[0]}<a
          href="https://indies.la"
          class="text-tx underline font-sans"
          target="_blank"
          rel="noopener noreferrer"
          >{content.online.desc.match(/\[(.*?)\]/)?.[1]}</a
        >{content.online.desc.split("]")[1]?.split(")")[1] || ""}
      </p>
    </div>
  </div>
  <div class="col-span-1 md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
    {
      content.lan.parties.map((party, i) => {
        const descHtml = party.desc.replace(
          /\[([^\]]+)\]\(([^)]+)\)/g,
          '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-tx underline font-sans">$1</a>',
        );
        return (
          <div class="border border-ui-2 p-2 flex flex-col gap-2">
            <div class="w-full aspect-square flex items-center justify-center overflow-hidden shrink-0">
              <div
                class="inline-block max-w-full max-h-full"
                style={`transform: scale(${lanAsciiScale[i]}); transform-origin: center;`}
              >
                <pre class="font-mono text-[4px] md:text-[5px] leading-none text-tx select-none">
                  {lanAsciiArt[i]}
                </pre>
              </div>
            </div>
            <div class="flex flex-col gap-2 text-center">
              <span class="text-xl md:text-2xl font-sans">{party.location}</span>
              <p
                class="text-tx-2 text-base text-balance max-w-prose mx-auto"
                set:html={descHtml}
              />
            </div>
          </div>
        );
      })
    }
  </div>
</div>
