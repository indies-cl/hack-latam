---
import { en } from "../../i18n/en";
import "../../styles/global.css";
import ApplyMarquee from "../../components/ApplyMarquee";
import Hero from "../../components/Hero.astro";
import ParticipateCTA from "../../components/ParticipateCTA.astro";
import Countdown from "../../components/Countdown";
import Bento from "../../components/Bento.astro";
import Sponsors from "../../components/Sponsors.astro";
import Communities from "../../components/Communities.astro";
import SEO from "../../components/SEO.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";

const { communities } = en.communities;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={en.meta.title} description={en.meta.description} />
  </head>
  <body class="bg-bg text-tx text-xl font-serif text-pretty">
    <ApplyMarquee word="participate" client:load />
    <div class="p-8 max-w-5xl mx-auto space-y-8">
      <Hero lang="en" />
      <section class="border border-ui bg-bg-2 p-6 md:p-10 flex flex-col gap-2 items-center justify-center text-center">
        <p class="text-tx-2">applications close</p>
        <Countdown lang="en" client:only="react" />
        <a href="https://tally.so/r/dWYX7o" target="_blank" rel="noopener noreferrer" class="text-og text-sm font-mono hover:underline">apply here →</a>
      </section>
      <div>
        <Bento lang="en" />
        <ParticipateCTA lang="en" />
      </div>
      <Sponsors lang="en" />
      <Communities
        communities={communities}
        title={en.communities.communitiesTitle}
      />
      <LanguageSwitcher currentLang="en" />
    </div>
  </body>
</html>
