---
import "../../styles/global.css";
import ApplyMarquee from "../../components/ApplyMarquee";
import TracksAccordion from "../../components/TracksAccordion";
import SEO from "../../components/SEO.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import { en } from "../../i18n/en";

const { tracksPage } = en;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={`${en.meta.title} | tracks`}
      description="hackathon tracks: transparency & corruption, environment & climate risk, defensive acceleration. limited spots."
    />
  </head>
  <body class="bg-bg text-tx text-xl font-serif text-pretty scroll-smooth">
    <ApplyMarquee word={en.landing.marquee} client:load />
    <main class="px-4 py-4 sm:p-8">
      <div class="max-w-3xl mx-auto space-y-12">
        <header class="space-y-4 text-center">
          <a href="/en" class="text-tx-2 text-sm font-mono hover:text-tx block text-left">
            {tracksPage.backToHome}
          </a>
          <h1 class="font-sans text-6xl">{tracksPage.title}</h1>
          <p class="text-tx-2 text-balance">{tracksPage.limitedSpots}</p>
          <p class="text-tx font-mono text-sm">{tracksPage.openSource}</p>
        </header>

        <TracksAccordion
          items={tracksPage.items}
          whatIsItLabel={tracksPage.whatIsIt}
          whatFitsLabel={tracksPage.whatFits}
          whatDoesntFitLabel={tracksPage.whatDoesntFit}
          client:load
        />

        <LanguageSwitcher currentLang="en" currentPath="/en/tracks" />
      </div>
    </main>
  </body>
</html>
